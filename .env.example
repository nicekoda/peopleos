# See docs/deployment.md for the full local vs. production guidance
# behind every "Production:" comment below. Never commit a real .env —
# this file only ever holds placeholders/local-safe defaults.

APP_NAME=PeopleOS
# Production: APP_ENV=production (never "local"/"testing" in production —
# several defaults elsewhere, e.g. error-detail exposure, key off this).
APP_ENV=local
# Production: a real key, generated once per environment via
# `php artisan key:generate` against that environment's own .env — never
# copy a key between environments, and never commit a real value here.
APP_KEY=
# Production: APP_DEBUG=false, always. A true value in production
# renders full stack traces (file paths, query bindings, source snippets)
# to any error response — see docs/security.md.
APP_DEBUG=true
# Production: the real HTTPS base URL of the deployment (e.g.
# https://peopleos.example.com). Must be HTTPS — see docs/deployment.md
# for why plain HTTP is not an acceptable production configuration here.
APP_URL=https://peopleos.test
# Drives tenant subdomain resolution (config/tenancy.php -> ResolveTenant
# middleware) — every tenant is {subdomain}.{APP_DOMAIN}. Production
# needs a real registered domain with wildcard DNS (*.yourdomain.com) —
# see docs/deployment.md "Tenant/Subdomain Deployment".
APP_DOMAIN=peopleos.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Production: LOG_LEVEL=info or warning (debug is noisy and can end up
# logging more request detail than intended) — see docs/deployment.md
# "Logging and Error Exposure". LOG_CHANNEL=stack is fine in both
# environments; just make sure the underlying log files/directory are
# not web-accessible and are rotated/retained per your own policy.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production: DB_CONNECTION=pgsql (unchanged), but DB_HOST/DB_PORT point
# at the real production database host, and DB_USERNAME/DB_PASSWORD must
# be strong, unique credentials for that environment only — never reuse
# local development credentials.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=peopleos_dev
DB_USERNAME=peopleos_user
DB_PASSWORD=

# Local/demo only — never a real credential, and never referenced by any
# production code path. Controls the password every seeded demo user
# (UserSeeder/DemoDataSeeder) is created with. See docs/security.md
# "Local Demo Credentials" and docs/demo-guide.md. Leave unset (or unused)
# entirely in a production .env — demo seeders should never run there
# at all; see docs/production-readiness.md.
SEED_USER_PASSWORD=

# Production: SESSION_DRIVER=database is fine as-is. SESSION_DOMAIN must
# be the real wildcard cookie domain (e.g. .yourdomain.com, leading dot)
# so the session cookie is shared correctly across every tenant
# subdomain — see docs/deployment.md "Tenant/Subdomain Deployment".
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.peopleos.test
# Production: SESSION_SECURE_COOKIE=true (required — the session cookie
# must never be sent over plain HTTP). Not set here because local
# development already runs over HTTPS via a locally-trusted cert (see
# README "Local Development Setup"), so the default (unset, meaning
# "secure only if the request itself is detected as HTTPS") already
# behaves correctly locally without needing to hardcode it.
# SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
# Production: FILESYSTEM_DISK=local is correct and should stay local —
# uploaded employee documents must never move to the `public` disk. See
# docs/deployment.md "File Storage Readiness".
FILESYSTEM_DISK=local
# No queued jobs exist in this app yet (nothing implements ShouldQueue) —
# QUEUE_CONNECTION=database is configured but currently unused in
# practice. See docs/deployment.md "Queue/Cache/Session Readiness".
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production: point at a real transactional mail provider/SMTP relay.
# MAIL_MAILER=log (the local/demo default) never actually sends
# anything — mail is written to the log instead, which is fine for
# local/demo. As of Checkpoint 44, password reset emails are the first
# real email this app sends (Illuminate\Auth\Notifications\ResetPassword,
# tenant-aware URL via AppServiceProvider::boot()) — locally you'll find
# the reset link in storage/logs/laravel.log rather than a real inbox.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
